# Postgres connection string from Neon (neon.tech, free tier) or any Postgres host
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Admin login for /admin
ADMIN_USERNAME="abeen"
# Generate with: npm run hash-password -- "yourpassword"
ADMIN_PASSWORD_HASH="$2a$10$replace-with-generated-hash"

# Random long random string, used to sign admin session tokens
JWT_SECRET="replace-with-a-long-random-string"
